script-source,77,node:internal/main/run_main_module,'use strict';\x0d\n\x0d\nconst {\x0d\n  RegExpPrototypeExec\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  prepareMainThreadExecution\x2C\x0d\n  markBootstrapComplete\x2C\x0d\n} = require('internal/process/pre_execution');\x0d\nconst { getOptionValue } = require('internal/options');\x0d\nconst { emitExperimentalWarning } = require('internal/util');\x0d\n\x0d\nconst isEntryURL = getOptionValue('--entry-url');\x0d\nconst mainEntry = prepareMainThreadExecution(!isEntryURL);\x0d\n\x0d\nmarkBootstrapComplete();\x0d\n\x0d\n// Necessary to reset RegExp statics before user code runs.\x0d\nRegExpPrototypeExec(/^/\x2C '');\x0d\n\x0d\nif (isEntryURL) {\x0d\n  emitExperimentalWarning('--entry-url');\x0d\n}\x0d\n\x0d\n/**\x0d\n * To support legacy monkey-patching of `Module.runMain`\x2C we call `runMain` here to have the CommonJS loader begin the\x0d\n * execution of the main entry point\x2C even if the ESM loader immediately takes over because the main entry is an ES\x0d\n * module or one of the other opt-in conditions (such as the use of `--import`) are met. Users can monkey-patch before\x0d\n * the main entry point is loaded by doing so via scripts loaded through `--require`. This monkey-patchability is\x0d\n * undesirable and should be removed once the module customization hooks provide equivalent functionality.\x0d\n */\x0d\nrequire('internal/modules/cjs/loader').Module.runMain(mainEntry);\x0d\n
