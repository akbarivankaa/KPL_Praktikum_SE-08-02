mod[kFormat] };\x0d\n}\x0d\n\x0d\nfunction reconstructErrorStack(err\x2C parentPath\x2C parentSource) {\x0d\n  const errLine = StringPrototypeSplit(\x0d\n    StringPrototypeSlice(err.stack\x2C StringPrototypeIndexOf(\x0d\n      err.stack\x2C '    at '))\x2C '\\n'\x2C 1)[0];\x0d\n  const { 1: line\x2C 2: col } =\x0d\n    RegExpPrototypeExec(/(\\d+):(\\d+)\\)/\x2C errLine) || [];\x0d\n  if (line && col) {\x0d\n    const srcLine = StringPrototypeSplit(parentSource\x2C '\\n'\x2C line)[line - 1];\x0d\n    const frame = `${parentPath}:${line}\\n${srcLine}\\n${StringPrototypeRepeat(' '\x2C col - 1)}^\\n`;\x0d\n    setArrowMessage(err\x2C frame);\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * Generate the legacy ERR_REQUIRE_ESM for the cases where require(esm) is disabled.\x0d\n * @param {Module} mod The module being required.\x0d\n * @param {undefined|object} pkg Data of the nearest package.json of the module.\x0d\n * @param {string} content Source code of the module.\x0d\n * @param {string} filename Filename of the module\x0d\n * @returns {Error}\x0d\n */\x0d\nfunction getRequireESMError(mod\x2C pkg\x2C content\x2C filename) {\x0d\n  // This is an error path because `require` of a `.js` file in a `"type": "module"` scope is not allowed.\x0d\n  const parent = mod[kFirstModuleParent];\x0d\n  const parentPath = parent?.filename;\x0d\n  const packageJsonPath = pkg?.path;\x0d\n  const usesEsm = containsModuleSyntax(content\x2C filename);\x0d\n  const err = new ERR_REQUIRE_ESM(filename\x2C usesEsm\x2C parentPath\x2C\x0d\n                                  packageJsonPath);\x0d\n  // Attempt to reconstruct the parent require frame.\x0d\n  const parentModule = Module._cache[parentPath];\x0d\n  if (parentModule) {\x0d\n    let parentSource;\x0d\n    try {\x0d\n      ({ source: parentSource } = loadSource(parentModule\x2C parentPath));\x0d\n    } catch {\x0d\n      // Continue regardless of error.\x0d\n    }\x0d\n    if (parentSource) {\x0d\n      // TODO(joyeecheung): trim off internal frames from the stack.\x0d\n      reconstructErrorStack(err\x2C parentPath\x2C parentSource);\x0d\n    }\x0d\n  }\x0d\n  return err;\x0d\n}\x0d\n\x0d\n/**\x0d\n * Built-in handler for `.js` files.\x0d\n * @param {Module} module The module to compile\x0d\n * @param {string} filename The file path of the module\x0d\n */\x0d\nModule._extensions['.js'] = function(module\x2C filename) {\x0d\n  let format\x2C pkg;\x0d\n  const tsEnabled = getOptionValue('--strip-types');\x0d\n  if (StringPrototypeEndsWith(filename\x2C '.cjs')) {\x0d\n    format = 'commonjs';\x0d\n  } else if (StringPrototypeEndsWith(filename\x2C '.mjs')) {\x0d\n    format = 'module';\x0d\n  } else if (StringPrototypeEndsWith(filename\x2C '.js')) {\x0d\n    pkg = packageJsonReader.getNearestParentPackageJSON(filename);\x0d\n    const typeFromPjson = pkg?.data.type;\x0d\n    if (typeFromPjson === 'module' || typeFromPjson === 'commonjs' || !typeFromPjson) {\x0d\n      format = typeFromPjson;\x0d\n    }\x0d\n  } else if (StringPrototypeEndsWith(filename\x2C '.mts') && tsEnabled) {\x0d\n    format = 'module-typescript';\x0d\n  } else if (StringPrototypeEndsWith(filename\x2C '.cts') && tsEnabled) {\x0d\n    format = 'commonjs-typescript';\x0d\n  } else if (StringPrototypeEndsWith(filename\x2C '.ts') && tsEnabled) {\x0d\n    pkg = packageJsonReader.getNearestParentPackageJSON(filename);\x0d\n    const typeFromPjson = pkg?.data.type;\x0d\n    if (typeFromPjson === 'module') {\x0d\n      format = 'module-typescript';\x0d\n    } else if (typeFromPjson === 'commonjs') {\x0d\n      format = 'commonjs-typescript';\x0d\n    } else {\x0d\n      format = 'typescript';\x0d\n    }\x0d\n  }\x0d\n  const { source\x2C format: loadedFormat } = loadSource(module\x2C filename\x2C format);\x0d\n  // Function require shouldn't be used in ES modules when require(esm) is disabled.\x0d\n  if ((loadedFormat === 'module' || loadedFormat === 'module-typescript') &&\x0d\n    !getOptionValue('--experimental-require-module')) {\x0d\n    cons