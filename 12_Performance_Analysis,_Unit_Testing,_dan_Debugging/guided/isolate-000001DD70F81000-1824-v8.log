script-source,14,node:internal/options,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypeMap\x2C\x0d\n  ArrayPrototypeSort\x2C\x0d\n  ObjectFromEntries\x2C\x0d\n  ObjectKeys\x2C\x0d\n  StringPrototypeReplace\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  getCLIOptionsValues\x2C\x0d\n  getCLIOptionsInfo\x2C\x0d\n  getOptionsAsFlags\x2C\x0d\n  getEmbedderOptions: getEmbedderOptionsFromBinding\x2C\x0d\n  getEnvOptionsInputType\x2C\x0d\n  getNamespaceOptionsInputType\x2C\x0d\n} = internalBinding('options');\x0d\n\x0d\nlet warnOnAllowUnauthorized = true;\x0d\n\x0d\nlet optionsDict;\x0d\nlet cliInfo;\x0d\nlet embedderOptions;\x0d\nlet optionsFlags;\x0d\n\x0d\n// getCLIOptionsValues() would serialize the option values from C++ land.\x0d\n// It would error if the values are queried before bootstrap is\x0d\n// complete so that we don't accidentally include runtime-dependent\x0d\n// states into a runtime-independent snapshot.\x0d\nfunction getCLIOptionsFromBinding() {\x0d\n  return optionsDict ??= getCLIOptionsValues();\x0d\n}\x0d\n\x0d\nfunction getCLIOptionsInfoFromBinding() {\x0d\n  return cliInfo ??= getCLIOptionsInfo();\x0d\n}\x0d\n\x0d\nfunction getOptionsAsFlagsFromBinding() {\x0d\n  return optionsFlags ??= getOptionsAsFlags();\x0d\n}\x0d\n\x0d\nfunction getEmbedderOptions() {\x0d\n  return embedderOptions ??= getEmbedderOptionsFromBinding();\x0d\n}\x0d\n\x0d\nfunction generateConfigJsonSchema() {\x0d\n  const envOptionsMap = getEnvOptionsInputType();\x0d\n  const namespaceOptionsMap = getNamespaceOptionsInputType();\x0d\n\x0d\n  function createPropertyForType(type) {\x0d\n    if (type === 'array') {\x0d\n      return {\x0d\n        __proto__: null\x2C\x0d\n        oneOf: [\x0d\n          { __proto__: null\x2C type: 'string' }\x2C\x0d\n          { __proto__: null\x2C items: { __proto__: null\x2C type: 'string'\x2C minItems: 1 }\x2C type: 'array' }\x2C\x0d\n        ]\x2C\x0d\n      };\x0d\n    }\x0d\n\x0d\n    return { __proto__: null\x2C type };\x0d\n  }\x0d\n